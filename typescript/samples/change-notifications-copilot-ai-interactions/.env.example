# Environment variables for Copilot AI Interaction Change Notifications
# Copy this file to .env and fill in your values.
#
# See README.md for full setup instructions.

# Microsoft Entra app registration
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# Target user (Azure AD object ID of the user with a Copilot Chat license)
USER_ID=your-user-object-id

# Server
PORT=3000

# Dev Tunnel notification URL (update after starting the tunnel)
NOTIFICATION_URL=https://your-devtunnel-url.devtunnels.ms/api/notifications

# Encryption certificate ID (must match the ID used when creating the subscription)
ENCRYPTION_CERTIFICATE_ID=copilot-change-notifications-cert

# Log level: debug | info | warn | error  (default: info)
LOG_LEVEL=info
