{
    "name": "copilot-change-notifications",
    "version": "1.0.0",
    "description": "Webhook server for Microsoft 365 Copilot AI interaction change notifications (TypeScript)",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "npm run build && node dist/server.js",
        "dev": "npx ts-node src/server.ts",
        "generate-cert": "npx ts-node src/generate-certificate.ts",
        "create-subscription": "npx ts-node src/create-subscription.ts"
    },
    "dependencies": {
        "@azure/identity": "^4.0.0",
        "@microsoft/microsoft-graph-client": "^3.0.7",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "isomorphic-fetch": "^3.0.0",
        "node-forge": "^1.3.1"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.0",
        "@types/node-forge": "^1.3.11",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    }
}