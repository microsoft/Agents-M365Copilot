# Azure AD App Registration Configuration
# Create an app registration in Azure Portal: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade

# Required: Your Azure AD Tenant ID
TENANT_ID=your-tenant-id-here

# Required: Your Azure AD Application (client) ID
CLIENT_ID=your-client-id-here

# Optional: Client Secret (for app-only authentication)
# If not provided, device code flow will be used for user authentication
CLIENT_SECRET=your-client-secret-here

# Optional: Server port
PORT=3000
